{
  "name": "truco-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm run dev -w @truco/server\" \"npm run dev -w @truco/web\"",
    "dev:proxy": "npm run dev",
    "dev:server": "npm run dev -w @truco/server",
    "dev:web": "npm run dev -w @truco/web",
    "build:server": "npm run build -w @truco/server",
    "start:server": "npm run start -w @truco/server",
    "build:web": "npm run build -w @truco/web",
    "build": "npm run build -w @truco/server && npm run build -w @truco/web",
    "lint": "npm run lint:types && npm run lint:eslint",
    "lint:types": "npm run lint --workspaces --if-present",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --pool=threads",
    "clean": "rimraf dist apps/server/dist apps/web/dist coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.2.4"
  }
}
