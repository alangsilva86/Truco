# Local development: Vite proxy target for the web app.
TRUCO_PROXY_TARGET=http://127.0.0.1:2567

# Local or production: comma-separated list of allowed HTTP origins for the server.
# Supports wildcards, e.g. https://*.railway.app
TRUCO_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://*.railway.app

# Production: public URLs used by the backend to generate shared invite links.
PUBLIC_SERVER_URL=
PUBLIC_WEB_URL=

# Production: Postgres persistence for users, rooms and participants.
DATABASE_URL=

# Production: shared Redis for Colyseus presence and room directory.
REDIS_URI=

# Server-side reconnect window in seconds.
RECONNECT_WINDOW_SECONDS=60

# Optional backend log level.
LOG_LEVEL=info

# Optional: Railway runtime selector when using the root `npm start`.
# Use `server` on the API/realtime service and `web` on the frontend service.
APP_RUNTIME=

# Optional: override HTTP room lookup/version/health origin.
# Leave empty in local development to use the Vite proxy.
VITE_SERVER_HTTP_URL=

# Optional: override the Colyseus websocket origin.
# Leave empty in local development to use ws://<current-host>:2567.
VITE_SERVER_WS_URL=

# Optional: total client-side recovery budget in milliseconds.
# Vite only exposes env vars prefixed with VITE_ to the browser bundle.
VITE_CLIENT_RECONNECT_BUDGET_MS=55000
