{
  "name": "@truco/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsup --config tsup.config.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@colyseus/redis-driver": "^0.17.6",
    "@colyseus/redis-presence": "^0.17.6",
    "@colyseus/schema": "^4.0.17",
    "@colyseus/tools": "^0.17.0",
    "@truco/contracts": "*",
    "@truco/engine": "*",
    "colyseus": "^0.17.8",
    "@prisma/client": "^6.8.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@colyseus/sdk": "^0.17.17",
    "@colyseus/testing": "^0.17.10",
    "@types/express": "^5.0.3",
    "prisma": "^6.8.2",
    "tsup": "^8.5.0"
  }
}
